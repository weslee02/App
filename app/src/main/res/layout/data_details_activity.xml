<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter patient information for adherence analysis"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingBottom="20dp"/>

        <EditText
            android:id="@+id/etAge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Age"
            android:inputType="number"
            android:minHeight="54dp" />

        <EditText
            android:id="@+id/etMissedDoses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Number of missed doses"
            android:minHeight="54dp"
            android:paddingTop="25dp"
            android:inputType="number"/>

        <EditText
            android:id="@+id/etDistance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Distance to facility (km)"
            android:minHeight="54dp"
            android:paddingTop="25dp"
            android:inputType="numberDecimal"/>

        <EditText
            android:id="@+id/etPreviousTB"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="54dp"
            android:paddingTop="25dp"
            android:hint="Previous TB treatment (Yes/No)"/>

        <EditText
            android:id="@+id/etAlcoholUse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Alcohol use (Yes/No)"
            android:minHeight="54dp"
            android:paddingTop="25dp"
            android:inputType="" />

        <Button
            android:id="@+id/btnAnalyze"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="Analyze" />

    </LinearLayout>

</ScrollView>
